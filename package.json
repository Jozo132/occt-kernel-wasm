{
  "name": "occt-kernel-wasm",
  "version": "1.1.0",
  "description": "Reusable OCCT-based CAD kernel for WebAssembly with a small TypeScript API for exact solid modelling",
  "author": "Jože Vovk",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "browser": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "jsdelivr": "dist/index.mjs",
  "unpkg": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./sketch-toolkit": {
      "types": "./dist/sketch-toolkit.d.ts",
      "import": "./dist/sketch-toolkit.mjs",
      "require": "./dist/sketch-toolkit.js"
    },
    "./occt-kernel.st.js": "./dist/occt-kernel.st.js",
    "./occt-kernel.st.wasm": "./dist/occt-kernel.st.wasm",
    "./occt-kernel.mt.js": "./dist/occt-kernel.mt.js",
    "./occt-kernel.mt.wasm": "./dist/occt-kernel.mt.wasm",
    "./sketch-toolkit.wasm.js": "./dist/sketch-toolkit.wasm.js",
    "./sketch-toolkit.wasm": "./dist/sketch-toolkit.wasm.wasm",
    "./occt-kernel.js": "./dist/occt-kernel.js",
    "./occt-kernel.wasm": "./dist/occt-kernel.wasm"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "NOTICE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "scripts": {
    "build": "node scripts/build-dist.mjs",
    "build:all": "npm run build:occt:all && npm run build:wasm:all && npm run build:sketch && npm run build",
    "build:wasm": "node scripts/run-platform-build.mjs wasm release st",
    "build:wasm:st": "node scripts/run-platform-build.mjs wasm release st",
    "build:wasm:mt": "node scripts/run-platform-build.mjs wasm release mt",
    "build:wasm:all": "node scripts/run-platform-build.mjs wasm release all",
    "build:wasm:fast": "node scripts/run-platform-build.mjs wasm fast st",
    "build:wasm:fast:all": "node scripts/run-platform-build.mjs wasm fast all",
    "build:sketch": "node scripts/run-platform-build.mjs sketch release",
    "build:sketch:debug": "node scripts/run-platform-build.mjs sketch debug",
    "build:sketch:fast": "node scripts/run-platform-build.mjs sketch fast",
    "build:occt": "node scripts/run-platform-build.mjs occt st",
    "build:occt:st": "node scripts/run-platform-build.mjs occt st",
    "build:occt:mt": "node scripts/run-platform-build.mjs occt mt",
    "build:occt:all": "node scripts/run-platform-build.mjs occt all",
    "build:native": "bash scripts/build-native.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --project tsconfig.check.json",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build:sketch && npm run build && npm run pack:check"
  },
  "keywords": [
    "occt",
    "opencascade",
    "cad",
    "wasm",
    "webassembly",
    "solid-modelling",
    "brep",
    "step",
    "geometry"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jozo132/occt-kernel-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/Jozo132/occt-kernel-wasm/issues"
  },
  "homepage": "https://github.com/Jozo132/occt-kernel-wasm#readme",
  "devDependencies": {
    "esbuild": "^0.25.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "moduleNameMapper": {
      "^../dist/occt-kernel\\.js$": "<rootDir>/src/mock-adapter.ts"
    }
  }
}
