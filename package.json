{
  "name": "occt-kernel-wasm",
  "version": "1.0.0",
  "description": "Reusable OCCT-based CAD kernel for WebAssembly with a small TypeScript API for exact solid modelling",
  "author": "Jože Vovk",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "NOTICE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:occt": "bash scripts/build-occt.sh",
    "build:native": "bash scripts/build-native.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "occt",
    "opencascade",
    "cad",
    "wasm",
    "webassembly",
    "solid-modelling",
    "brep",
    "step",
    "geometry"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Jozo132/occt-kernel-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/Jozo132/occt-kernel-wasm/issues"
  },
  "homepage": "https://github.com/Jozo132/occt-kernel-wasm#readme",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "moduleNameMapper": {
      "^../dist/occt-kernel\\.js$": "<rootDir>/src/mock-adapter.ts"
    }
  }
}
